SECRET_KEY=change-me
DEBUG=1
ALLOWED_HOSTS=localhost,127.0.0.1
# Origins the browser uses to reach the app. Required for login/POST under the
# prod settings (DEBUG=False) — must include the scheme and the port you browse
# to. The docker-compose demo serves nginx on 8080:
CSRF_TRUSTED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080
POSTGRES_DB=cmms
POSTGRES_USER=cmms
POSTGRES_PASSWORD=cmms
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
TIME_ZONE=Asia/Karachi
HOSPITAL_NAME=Demo General Hospital

# Shared login password for the demo accounts created by `manage.py seed_demo`
# (users: admin, engineer1-3, staff1-10). Anyone can clone the repo and log in
# with this to try the UI. Change it before any real deployment.
DEMO_PASSWORD=demo1234

# --- Production admin bootstrap (optional) ----------------------------------
# Uncomment and set a REAL password to auto-create the initial admin on deploy
# via `manage.py create_superuser` (idempotent; skips if a superuser exists or
# these are unset). Leave commented to skip and use `createsuperuser`
# interactively instead. NEVER commit a real password — set it only in your
# private .env. After first login, create real per-person accounts in /admin/.
# SUPERUSER_USERNAME=admin
# SUPERUSER_EMAIL=admin@hospital.example
# SUPERUSER_PASSWORD=
# SUPERUSER_EMPLOYEE_ID=ADMIN-0001

# Phase 2 (LLM) — unused in Phase 1
OLLAMA_MODEL=llama3.1:8b
